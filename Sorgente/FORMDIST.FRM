                            If CC(K, I) > 10 Then Ascissa = Mezzeria - (PassoOrizzontale * CC(K, I) / 2) + PassoOrizzontale - 4.5
                        For J = 1 To CC(K, I)
                            Picture1.Circle (Ascissa, 339 - (ValoreCentrale(I) - YIN) * FY), 4, QBColor(0)
