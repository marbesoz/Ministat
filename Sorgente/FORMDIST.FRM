Private Sub Form_Load()
    On Error GoTo GestioneErroriDistribuzione
    Dim I, J, K, Riga, Z1, Dummy As Double
    Dim ValoreInizialeD, D, L, XX, M1, M2
    Dim N, R

    Screen.MousePointer = 11
    
    NUMCOLONNE = FormPrincipale!Grid1.SelEndCol - FormPrincipale!Grid1.SelStartCol + 1
    CL = 340

    ReDim X(NUMCOLONNE, NUM_RIGHE - 1) As Double
    ReDim Y(NUMCOLONNE, NUM_RIGHE - 1) As Double
    ReDim NomeVariabile(NUMCOLONNE)
    ReDim NumDati(NUMCOLONNE)
    ReDim FineDati(NUMCOLONNE)
    ReDim Minimo(NUMCOLONNE)
    ReDim Massimo(NUMCOLONNE)
    ReDim PrimoQ(NUMCOLONNE)
    ReDim SecondoQ(NUMCOLONNE)
    ReDim TerzoQ(NUMCOLONNE)
    ReDim CC(NUMCOLONNE, CL)
    ReDim ValoreCentrale(CL)

    AnnullatoCaricamentoForm = False
    FlagGrafico = False
    Picture2.Visible = False
    
' centra il form
    FormDistribuzione.Top = Screen.Height / 2 - Height / 2
    FormDistribuzione.Left = Screen.Width / 2 - Width / 2
' sposta in alto a sinistra
    Text4.Move 0, 0
' dimensionamento, ripreso nella sub resize
    Text4.Width = ScaleWidth
    Text4.Height = ScaleHeight
' inizializza
    Text4.Text = ""
    Text4.Enabled = False
' nome delle variabili
    
    FormPrincipale!Grid1.Row = 0
    K = 0
    For I = FormPrincipale!Grid1.SelStartCol To FormPrincipale!Grid1.SelEndCol
        K = K + 1
        FormPrincipale!Grid1.Col = I
        NomeVariabile(K) = FormPrincipale!Grid1.Text
    Next I

    Titolo = "Diagramma di distribuzione"
    InOrdinate = "Grandezza e unitŕ in ordinate"
    FlagSfondoGrigio = True
    FlagDatiAColori = True

    FormGauge.Show
    FormGauge.Caption = "Diagramma di distribuzione"
    FormGauge!Label1.Refresh: FormGauge!Gauge1.Refresh

' carica i dati nel vettore X()
    For I = 1 To NUMCOLONNE
        NumDati(I) = 0
        FineDati(I) = False
    Next I

    K = 0
    For I = FormPrincipale!Grid1.SelStartCol To FormPrincipale!Grid1.SelEndCol
        FormPrincipale!Grid1.Col = I
        K = K + 1
        FormGauge!Label6.Caption = "[" & K & "/" & NUMCOLONNE * 2 & "]"
        For Riga = 1 To NUM_RIGHE - 1
            If 100 * Riga / (NUM_RIGHE - 1) = Int(100 * Riga / (NUM_RIGHE - 1)) Then
                FormGauge.Label1.Caption = Int(100 * Riga / (NUM_RIGHE - 1)) & "%"
                FormGauge!Gauge1.Value = Int(100 * Riga / (NUM_RIGHE - 1))
                FormGauge!Label1.Refresh: FormGauge!Gauge1.Refresh
            End If
        FormPrincipale!Grid1.Row = Riga
        
        If FineDati(K) = False Then
            If FormPrincipale!Grid1.Text <> "" Then
                NumDati(K) = NumDati(K) + 1
                X(K, Riga) = CDbl(-(-FormPrincipale!Grid1.Text))
            Else
                FineDati(K) = True
            End If
        End If
        
        Next Riga
    Next I

' controlli finali sui dati
' devono esserci almeno tre dati per ciascuna variabile
    Dummy = True
    For I = 1 To NUMCOLONNE
        If NumDati(I) < 3 Then Dummy = False
    Next I

    If Dummy = False Then
        Unload FormGauge
        AnnullatoCaricamentoForm = True
        Screen.MousePointer = 1
        MsgBox "Per il diagramma di distribuzione" + Chr(10) + "sono necessari almeno tre dati.", MB_OK + MB_ICONSTOP + MB_DEFBUTTON1, "Dati non rappresentabili"
        FormPrincipale!Grid1.HighLight = True
        RipristinaSchermo
        Exit Sub
    End If

' altrimenti continua

        YMI = X(1, 1): YMA = X(1, 1)
        For K = 1 To NUMCOLONNE
            Minimo(K) = X(K, 1): Massimo(K) = X(K, NumDati(K))
            For I = 1 To NumDati(K)
                If X(K, I) < YMI Then YMI = X(K, I)
                If X(K, I) > YMA Then YMA = X(K, I)
            Next I
        Next K
        YMI_Default = YMI: YMA_Default = YMA

' suddivisione in classi
        
        Z1 = NumDati(1)
        For K = 1 To NUMCOLONNE
            If Z1 < NumDati(K) Then Z1 = NumDati(K)
        Next K

        LW = YMI
        HI = YMA
        AM = (HI - LW) / CL
        MX = 0
            
    For K = 1 To NUMCOLONNE
        Z1 = NumDati(K)
        
        FormGauge!Label6.Caption = "[" & NUMCOLONNE + K & "/" & NUMCOLONNE * 2 & "]"
            
            For N = 1 To Z1
                FormGauge.Label1.Caption = Int(100 * N / Z1) & "%"
                FormGauge!Gauge1.Value = Int(100 * N / Z1)
                FormGauge!Label1.Refresh: FormGauge!Gauge1.Refresh
                R = CL
                If X(K, N) = HI Then GoTo 4444
                R = Int((X(K, N) - LW) / AM) + 1
4444:
                CC(K, R) = CC(K, R) + 1
            Next N
                
                For I = 1 To CL
                    If CC(K, I) > MX Then MX = CC(K, I)
                Next I
    Next K
    
        For I = 1 To CL
            ValoreCentrale(I) = LW + ((I - 1) * AM) + (AM / 2)
        Next I

        Unload FormGauge
        Text4.Visible = True
        FormPrincipale!Grid1.HighLight = True
        RipristinaSchermo
        FormDistribuzione.Show
        ' FormPrincipale.Hide
        GraficaX_Click
        Screen.MousePointer = 1

Exit Sub

GestioneErroriDistribuzione:
        Unload FormGauge
        Screen.MousePointer = 1
        MsgBox "Memoria insufficiente: riprovare" + Chr(10) + "con un numero inferiore di dati.", MB_OK + MB_ICONSTOP + MB_DEFBUTTON1, "Dati non rappresentabili"
        FormPrincipale!Grid1.HighLight = True
        RipristinaSchermo
        Exit Sub

End Sub

