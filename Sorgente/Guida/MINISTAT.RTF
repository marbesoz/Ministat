\fs20\lang1040\cgrid {\cs16\super $}{\f16\fs24\cgrid0 Statistica non parametrica: Regressione lineare}}K{\footnote \pard\plain \sl240\slmult0\nowidctlpar\widctlpar\adjustright \fs20\lang1040\cgrid {\cs16\super K}{\f16\fs24\cgrid0 
