. Padova: Piccin, 1980:237pp. 
\par \page }{\cs16\super #{\footnote \pard\plain \sl240\slmult0\nowidctlpar\widctlpar\adjustright \fs20\lang1040\cgrid {\cs16\super #}{\f16\fs24\cgrid0 StatisticaStatisticaBayesianaDue}}}{\f5\cgrid0 
